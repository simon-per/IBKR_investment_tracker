# Backend environment configuration — TEMPLATE.
# Copy to backend/.env and fill in real values. backend/.env is gitignored
# (it holds secrets); this .example file is the only env file committed to git.

# --- IBKR Flex Web Service (required) ---
# Token:    IBKR portal > Reports > Settings > Flex Web Service
# Query ID: IBKR portal > Reports > Flex Queries > Custom Flex Queries > Configure
IBKR_TOKEN=your_flex_query_token
IBKR_QUERY_ID=your_flex_query_id

# --- Optional ---
ALPHA_VANTAGE_API_KEY=

# --- Database ---
# SQLite file; persisted on the host via the docker bind mount in docker-compose.yml.
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# --- CORS (comma-separated allowed origins) ---
# Include the production domain plus any local dev origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://portfolio.srv1211053.hstgr.cloud
